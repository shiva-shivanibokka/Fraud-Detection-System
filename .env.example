# Fraud Detection System — environment variable reference
# Copy this file to .env and fill in real values for local development.
# Never commit .env to version control — it is listed in .gitignore.

# Host address the API server binds to
API_HOST=0.0.0.0

# Port the API server listens on
API_PORT=8000

# Local dev: redis://localhost:6379
# Upstash prod: rediss://:<password>@<host>.upstash.io:6380
REDIS_URL=redis://localhost:6379

# Supabase project URL (from Settings > API in the Supabase dashboard)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service-role secret key (keep private — grants full DB access)
SUPABASE_KEY=your-supabase-service-role-key

# Allowed CORS origins for the API (comma-separated list in a JSON array)
CORS_ORIGINS=["http://localhost:5173"]

# Directory containing model artifact files (.onnx, .pkl, .json)
MODEL_DIR=models

# Fraud score threshold above which a transaction is flagged for REVIEW
FRAUD_THRESHOLD_REVIEW=0.4

# Fraud score threshold above which a transaction is DECLINED outright
FRAUD_THRESHOLD_DECLINE=0.8

# Hugging Face Hub repo ID for model registry (e.g. org/fraud-model)
HF_REPO_ID=your-hf-username/fraud-detection-model

# LLM copilot DEFAULT provider hint: "openai" or "groq". Note: the copilot is
# bring-your-own-key — real keys arrive per-request from the browser via the
# X-LLM-Key header and are NEVER read from the server env or stored.
LLM_PROVIDER=openai

# Deployed model version tag recorded in every scoring decision
MODEL_VERSION=1.0.0

# --- Analyst feedback loop -------------------------------------------------
# Where ✓/✗ analyst labels are written (JSONL). When SUPABASE_* are set, each
# label is also best-effort inserted into the Supabase "analyst_feedback" table.
FEEDBACK_PATH=data/feedback.jsonl

# --- Live transaction feed (Supabase Realtime) -----------------------------
# Best-effort publish of each decision to LIVE_FEED_TABLE (requires SUPABASE_*).
# Set LIVE_FEED_ENABLED=false to disable publishing entirely.
LIVE_FEED_ENABLED=true
LIVE_FEED_TABLE=live_decisions

# --- Observability (both optional; features no-op cleanly when unset) -------
# Sentry error tracking for the API. Leave blank to disable.
SENTRY_DSN=
# Deploy environment tag reported to Sentry: "production", "local", ...
ENVIRONMENT=local
# DagsHub / remote MLflow tracking URI for offline training runs. Leave blank
# to log locally to ./mlruns. (MLflow also honors MLFLOW_TRACKING_USERNAME /
# MLFLOW_TRACKING_PASSWORD for DagsHub auth.)
MLFLOW_TRACKING_URI=
