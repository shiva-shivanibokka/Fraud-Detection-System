# Fraud Detection System — environment variable reference
# Copy this file to .env and fill in real values for local development.
# Never commit .env to version control — it is listed in .gitignore.

# Host address the API server binds to
API_HOST=0.0.0.0

# Port the API server listens on
API_PORT=8000

# Local dev: redis://localhost:6379
# Upstash prod: rediss://:<password>@<host>.upstash.io:6380
REDIS_URL=redis://localhost:6379

# Supabase project URL (from Settings > API in the Supabase dashboard)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service-role secret key (keep private — grants full DB access)
SUPABASE_KEY=your-supabase-service-role-key

# Allowed CORS origins for the API (comma-separated list in a JSON array)
CORS_ORIGINS=["http://localhost:5173"]

# Directory containing model artifact files (.onnx, .pkl, .json)
MODEL_DIR=models

# Fraud score threshold above which a transaction is flagged for REVIEW
FRAUD_THRESHOLD_REVIEW=0.4

# Fraud score threshold above which a transaction is DECLINED outright
FRAUD_THRESHOLD_DECLINE=0.8

# Hugging Face Hub repo ID for model registry (e.g. org/fraud-model)
HF_REPO_ID=your-hf-username/fraud-detection-model

# LLM copilot backend provider: "openai" or "groq"
LLM_PROVIDER=openai

# Deployed model version tag recorded in every scoring decision
MODEL_VERSION=1.0.0
