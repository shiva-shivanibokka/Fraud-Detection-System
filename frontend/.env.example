# Frontend environment variables (Vite). Copy to .env.local for dev, or set in
# Vercel for production. All values here are public (no secrets): the Supabase
# anon key is row-level-security-scoped and the Sentry DSN is publishable.

# Backend API base URL (FastAPI on Render).
VITE_API_URL=http://localhost:8000

# Supabase Realtime — enables the Live Feed tab. Leave unset to hide the feed.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Sentry error tracking (React). Leave unset to disable.
VITE_SENTRY_DSN=
